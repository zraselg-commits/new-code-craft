# ============================================================
# Code Craft BD — Environment Variables
# Copy this file to .env.local for local dev
# On VPS: set these in /etc/environment or use the .env file
# ============================================================

# App
NODE_ENV=production
PORT=3000

# ─── Admin Authentication ────────────────────────────────────
# CHANGE THESE in production!
ADMIN_EMAIL=admin@codecraftbd.info
ADMIN_PASSWORD=your-strong-password-here
JWT_SECRET=your-very-long-random-secret-string-here-min-32-chars

# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://codecraftbd.info

# ─── Optional: Database (if migrating from file-based to DB) ─
# DATABASE_URL=postgresql://user:password@localhost:5432/codecraftbd

# ─── Optional: Firebase (if using Firestore) ─────────────────
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# ─── Optional: Telegram Bot (for WhatsApp widget) ────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
