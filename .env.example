# ============================================================
# Code Craft BD — Environment Variables
# Copy this file to .env.local for local dev
# On VPS: set these as system environment variables
# or copy to .env in the project root (NOT committed to git)
# ============================================================

# App
NODE_ENV=production
PORT=3000

# ─── Admin Authentication ────────────────────────────────────
# CHANGE THESE in production! Use a strong random password.
ADMIN_EMAIL=admin@codecraftbd.info
ADMIN_PASSWORD=your-strong-password-here

# JWT secret — generate with: openssl rand -hex 64
JWT_SECRET=your-very-long-random-secret-string-here-min-64-chars

# ─── NextAuth ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://codecraftbd.info

# ─── Telegram Bot (for WhatsApp/contact widget) ──────────────
# Set these here so they don't live in scripts/site-settings.json
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ─── Optional: Firebase (if using Firestore) ─────────────────
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Optional: Database (if migrating from file-based to DB) ─
# DATABASE_URL=postgresql://user:password@localhost:5432/codecraftbd
